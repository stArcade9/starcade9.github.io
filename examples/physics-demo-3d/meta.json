  "gameplay": {
    "physics": {
      "gravity": -15,
      "bounceDamping": 0.8,
      "airResistance": 0.995,
      "wallBounds": 24
    },
    "demos": {
      "bouncingSpheres": {
        "count": 12,
        "materials": 4
      },
      "pendulumChain": {
        "segments": 6,
        "spacing": 2,
        "constraintStrength": 0.8
      },
      "particleFountain": {
        "spawnRate": 0.1,
        "color": "#ff6600",
        "lifetime": 3
      },
      "gravityWell": {
        "orbiters": 8,
        "orbitRadius": 12,
        "fieldStrength": 50
      },
      "collisionCascade": {
        "dominoes": 10,
        "color": "#8844ff",
        "impulseColor": "#ff4444"
      },
      "sandbox": {
        "towerSize": [
          5,
          3
        ],
        "maxObjects": 60
      }
    },
    "particles": {
      "bounce": {
        "count": 3,
        "color": "#ffaa44",
        "lifetime": 1
      },
      "collision": {
        "count": 5,
        "color": "#ff4444",
        "lifetime": 0.8
      }
    }
  },
  "defaults": {
    "lighting": {
      "ambient": "#ffffff",
      "ambientIntensity": 0.6,
      "directional": {
        "direction": [
          0.5,
