          0.3
        ],
        "color": "#ffffff"
      }
    },
    "effects": {
      "bloom": {
        "strength": 0.6,
        "radius": 0.3,
        "threshold": 0.5
      }
    },
    "camera": {
      "orbitRadius": 25,
      "orbitHeight": 15
